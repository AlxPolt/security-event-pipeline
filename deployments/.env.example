NATS_USER=your_nats_username             # NATS auth username
NATS_PASSWORD=your_nats_password         # NATS auth password
NATS_SUBJECT=events_subject              # Primary pub/sub subject
NATS_STREAM=STREAM_EVENTS                # JetStream persistent stream

INFLUX_TOKEN=your_influxdb_admin_token   # Generated by: make certs
INFLUX_DB_EVENTS=events_db               # Target database

HOST_CERTS_DIR=./certs                   # Host certs path
HOST_NATS_CONFIG=./configs/nats/nats.conf # Host NATS config
CONT_CERTS_DIR=/certs                    # Container certs mount
CA_FILE=ca.pem                           # Root CA file
CLIENT_CERT=client.pem                   # Client public cert
CLIENT_KEY=client-key.pem                # Client private key
SERVER_CERT=server.pem                   # Server public cert
SERVER_KEY=server-key.pem                # Server private key

INTERNAL_SUBNET=172.28.0.0/24            # Internal CIDR block
READER_QUERY_SUBJECT=events_subject.query # Reader listen subject
CLIENT_QUERY_SUBJECT=events_subject.query # Client dispatch subject
X_CLIENT_MIN_CRITICALITY=1               # Min criticality filter
CLIENT_EVENT_LIMIT=10                    # Max events per response
CLIENT_REQUEST_TIMEOUT=5s                # Query timeout
